{
  "name": "supa-pi",
  "version": "1.0.0",
  "description": "Ethan's pi coding agent harness",
  "readme": "README.md",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions/questionnaire.ts",
      "./extensions/core-prompt",
      "./extensions/rules",
      "./extensions/plan",
      "./extensions/execute",
      "./extensions/research",
      "./extensions/simplify",
      "./extensions/session-query.ts",
      "./extensions/handoff.ts",
      "./extensions/context",
      "./extensions/btw",
      "./extensions/ast-grep",
      "./extensions/pi-rtk",
      "./extensions/init-deep",
      "./extensions/smart-docs",
      "./extensions/om",
      "./extensions/editor-enhancements",
      "./extensions/lsp",
      "./extensions/skills.ts"
    ]
  },
  "scripts": {
    "build:syntect-picker-preview": "node ./extensions/editor-enhancements/native/syntect-picker-preview/scripts/build.mjs",
    "build:syntect-picker-preview:debug": "node ./extensions/editor-enhancements/native/syntect-picker-preview/scripts/build.mjs --debug",
    "check:syntect-picker-preview": "cargo check --manifest-path ./extensions/editor-enhancements/native/syntect-picker-preview/Cargo.toml",
    "test:syntect-picker-preview": "cargo test --manifest-path ./extensions/editor-enhancements/native/syntect-picker-preview/Cargo.toml"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "ultracite": "^7.3.1"
  }
}
