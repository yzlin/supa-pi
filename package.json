{
  "name": "supa-pi",
  "version": "1.0.0",
  "description": "Ethan's pi coding agent harness",
  "license": "MIT",
  "readme": "README.md",
  "type": "module",
  "bin": {
    "docs-list": "./scripts/docs-list.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/questionnaire",
      "./extensions/caveman",
      "./extensions/core-prompt",
      "./extensions/rules",
      "./extensions/execute",
      "./extensions/goal",
      "./extensions/research",
      "./extensions/diagnose",
      "./extensions/code-improvement",
      "./extensions/review",
      "./extensions/session-query.ts",
      "./extensions/handoff.ts",
      "./extensions/context",
      "./extensions/context-docs",
      "./extensions/btw",
      "./extensions/rtk",
      "./extensions/tool-display",
      "./extensions/init-deep",
      "./extensions/smart-docs",
      "./extensions/docs-list",
      "./extensions/lsp",
      "./extensions/skills",
      "./extensions/obsidian",
      "./extensions/no-sleep.ts",
      "./extensions/whimsical",
      "./extensions/fast"
    ]
  },
  "dependencies": {
    "ignore": "^7.0.5"
  },
  "scripts": {
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun test"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "^1.1.34"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.12",
    "@yzlin/pieditor": "^1.0.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.3.1"
  }
}
