{
  "name": "supa-pi",
  "version": "1.0.0",
  "description": "Ethan's pi coding agent harness",
  "readme": "README.md",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions/questionnaire.ts",
      "./extensions/caveman",
      "./extensions/core-prompt",
      "./extensions/rules",
      "./extensions/plan",
      "./extensions/execute",
      "./extensions/research",
      "./extensions/simplify",
      "./extensions/review.ts",
      "./extensions/session-query.ts",
      "./extensions/handoff.ts",
      "./extensions/context",
      "./extensions/btw",
      "./extensions/ast-grep",
      "./extensions/rtk",
      "./extensions/init-deep",
      "./extensions/smart-docs",
      "./extensions/pieditor",
      "./extensions/lsp",
      "./extensions/web-access",
      "./extensions/skills.ts"
    ]
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "ignore": "^7.0.5",
    "linkedom": "^0.16.0",
    "p-limit": "^6.1.0",
    "turndown": "^7.2.0",
    "unpdf": "^1.4.0"
  },
  "scripts": {
    "build:syntect-picker-preview": "node ./extensions/pieditor/native/syntect-picker-preview/scripts/build.mjs",
    "build:syntect-picker-preview:debug": "node ./extensions/pieditor/native/syntect-picker-preview/scripts/build.mjs --debug",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "check:syntect-picker-preview": "cargo check --manifest-path ./extensions/pieditor/native/syntect-picker-preview/Cargo.toml",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test:syntect-picker-preview": "cargo test --manifest-path ./extensions/pieditor/native/syntect-picker-preview/Cargo.toml",
    "test": "bun test"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.12",
    "ultracite": "^7.3.1"
  }
}
